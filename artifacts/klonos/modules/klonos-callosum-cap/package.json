{
  "name": "@klonos/callosum-cap",
  "version": "0.0.0",
  "private": true,
  "description": "KlonOS Corpus Callosum — Capacitor Plugin (Android)",
  "main": "dist/esm/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "callosum",
    "klonos",
    "zerolag",
    "webauthn"
  ],
  "peerDependencies": {
    "@capacitor/core": "^7.0.0"
  },
  "dependencies": {
    "@capacitor/core": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "typescript": "^5.8.3"
  }
}
