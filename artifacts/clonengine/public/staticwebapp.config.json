{
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "globalHeaders": {
    "Cache-Control": "public, max-age=31536000, immutable"
  },
  "routeHeaders": {
    "/*.html": {
      "Cache-Control": "no-cache"
    },
    "/staticwebapp.config.json": {
      "Cache-Control": "no-cache"
    }
  }
}
