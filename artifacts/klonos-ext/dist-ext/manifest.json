{
  "manifest_version": 3,
  "name": "ZeroLag — Gaming Network Optimizer",
  "short_name": "ZeroLag",
  "version": "1.0.0",
  "description": "Real-time gaming latency optimizer powered by 302-neuron SNN AI. Finds your fastest Azure server automatically. Free Fire, Valorant, PUBG, Fortnite.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "ZeroLag · SNN Gaming Optimizer"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "<all_urls>",
    "https://*.blob.core.windows.net/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
